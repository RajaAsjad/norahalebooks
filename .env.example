APP_NAME="Nora Hale Books"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/revamp

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=revamp
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Site branding — Nora Hale Books
SITE_NAME="Nora Hale Books"
SITE_SHORT_NAME="NHB"
SITE_TAGLINE="Author of Castor Oil for Life"
SITE_DESCRIPTION="Wellness author Nora Hale shares science-backed books, recipes, and natural health wisdom."
SITE_SOURCE_URL="https://norahalebooks.com"
SITE_EMAIL=hello@norahalebooks.com
SITE_PHONE=""
SITE_PHONE_HREF=""
SITE_FOOTER_TEXT="Nora Hale is a retired Registered Nurse and wellness author helping readers embrace simple, science-backed habits."

# Theme colors — warm wellness palette
SITE_COLOR_PRIMARY="#2D6A4F"
SITE_COLOR_SECONDARY="#B8860B"
SITE_COLOR_ACCENT="#40916C"
SITE_COLOR_BG="#FAF8F4"
SITE_THEME_MODE=light

# Social links
SITE_FACEBOOK=https://www.facebook.com/norahalebooks
SITE_INSTAGRAM=
SITE_TWITTER=
SITE_LINKEDIN=
SITE_YOUTUBE=
SITE_SPOTIFY=
SITE_TIKTOK=

# Kit (ConvertKit) form embed URLs — paste from your Kit account
KIT_CONNECT_EMBED=
KIT_BONUSRECIPES_EMBED=
KIT_ARC_EMBED=
KIT_CONNECT_REDIRECT=https://norahalebooks.com/connect
KIT_BONUSRECIPES_REDIRECT=https://norahalebooks.com/bonusrecipes
KIT_ARC_REDIRECT=https://norahalebooks.com/ARCreaders

# Agency footer credit (hidden until revamp — set enabled=true to show)
SITE_AGENCY_ENABLED=false
SITE_AGENCY_NAME="US Design Agency"
SITE_AGENCY_URL=https://www.usdesignagency.com/
